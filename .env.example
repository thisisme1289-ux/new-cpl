# Frontend service
# Use your deployed Socket.IO backend URL in production.
VITE_SOCKET_URL=https://your-cpl-backend.up.railway.app

# Backend service
# Use your deployed frontend URL in production.
# Comma-separate multiple frontend domains if needed.
FRONTEND_URL=https://your-cpl-frontend.up.railway.app

# Railway sets PORT automatically for the backend.
# PORT=4000

# Optional local/deployed preflight targets for npm run check:deploy.
# These are read by scripts/check-deploy.js, not by the browser app.
CPL_BACKEND_URL=https://your-cpl-backend.up.railway.app
CPL_FRONTEND_URL=https://your-cpl-frontend.up.railway.app
